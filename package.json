{
  "name": "cargo-allocation-system",
  "version": "1.0.0",
  "description": "Maritime cargo-to-tank allocation service using Dinic max flow and Sequelize",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --require dotenv/config src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint . --ext .ts",
    "test": "jest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "sequelize": "^6.32.1",
    "sequelize-typescript": "^2.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.18",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.14.2",
    "ts-jest": "^29.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "jest": "^29.6.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
